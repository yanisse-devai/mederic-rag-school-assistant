    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nreturn items.map(item => {\n  const texte = item.json.texte;\n\n  const nettoye = texte\n    .replace(/\\[javascript:[^\\]]+\\]/g, '')\n    .replace(/\\[https?:\\/\\/[^\\]]+\\]/g, '')\n    .replace(/https?:\\/\\/\\S+/g, '')\n    .replace(/\\n{3,}/g, '\\n\\n')\n    .split('\\n')\n    .filter(ligne => {\n      const l = ligne.trim();\n      if (l.length === 0) return false;\n\n      const bruit = [\n        'nous suivre', 'réseaux sociaux', 'politique de', 'mentions légales',\n        'préférences', 'logo', '@ 20', 'actions de formation', 'je découvre',\n        'je souhaite', 'je candidate', 'nous rencontrer', 'en savoir plus',\n        'vous souhaitez', 'contactez-nous', 'certification qualité',\n        'informations & candidatures', 'notre soirée', 'téléchargez'\n      ];\n      if (bruit.some(b => l.toLowerCase().includes(b))) return false;\n      if (l.startsWith('*')) return false;\n      if (/\\d/.test(l)) return true;\n      if (l.length < 25) return false;\n\n      return true;\n    })\n    .join('\\n')\n    .trim();\n\n  return { json: { texte: nettoye } };\n});"
      },
