    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nreturn items.map(item => {\n  const texte = item.json.text || '';\n\n  const nettoye = texte\n    .replace(/^\\s*\\d+\\s*$/gm, '')\n    .split('\\n')\n    .filter(ligne => {\n      const l = ligne.trim();\n      if (l.length === 0) return false;\n      if (l.length < 15) return false;\n      return true;\n    })\n    .join('\\n')\n    .replace(/\\n{3,}/g, '\\n\\n')\n    .trim();\n\n  return { json: { texte: nettoye } };\n});"
      },
